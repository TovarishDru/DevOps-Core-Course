---
# Example file for group_vars/all.yml
# Copy this file to all.yml and encrypt it with Ansible Vault:
#   cp all.yml.example all.yml
#   ansible-vault encrypt all.yml
#
# Or create encrypted file directly:
#   ansible-vault create all.yml

# Docker Hub credentials
dockerhub_username: your-dockerhub-username
dockerhub_password: your-dockerhub-access-token

# Application configuration
app_name: devops-python-app
docker_image: "{{ dockerhub_username }}/{{ app_name }}"
docker_image_tag: latest
app_host_port: 5000
app_container_port: 8000
app_container_name: "{{ app_name }}"